pushfn main
call 0
halt

println:
  loadg 0
  pushs "printf"
  object_get
  load 0
  load 1
  call 2
  ret_void

main:
  enter 1
  pushs "./modules/std"
  load_lib
  storeg 0
  pushfn println
  object_new
  dup
  store 0
  pushs "x"
  pushi 15
  object_set
  pushs "X should be 15 => %d\n"
  swap
  pushs "x"
  object_get
  call 2
  pushfn println
  swap
  pushs "x"
  object_del
  object_len
  pushs "Key deleted, Object length must be 0 => %d\n"
  swap
  call 2
  pushi 0
  ret



